    {
      "type": "timeseries",
      "id": 1,
      "title": "/checkout request rate (by status class)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 1},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (status_class) (rate(checkout_requests_total[1m]))",
          "legendFormat": "{{status_class}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []},
      "options": {"legend": {"showLegend": true, "displayMode": "list"}, "tooltip": {"mode": "single"}}
    },
    {
      "type": "timeseries",
      "id": 2,
      "title": "/checkout latency (p50, p95, p99)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 1},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(checkout_latency_seconds_bucket[1m])))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(checkout_latency_seconds_bucket[1m])))",
          "legendFormat": "p95"
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(checkout_latency_seconds_bucket[1m])))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []},
      "options": {"legend": {"showLegend": true, "displayMode": "list"}, "tooltip": {"mode": "multi"}}
    },
